# TrendRadar Admin deployment settings
# Copy to .env or export these variables before running deploy/install.sh.

# Existing TrendRadar root. Must contain docs/index.html and config/config.yaml.
TRENDRADAR_DIR=/opt/trendradar

# Docker image used by your TrendRadar deployment.
# Use the same image as the main TrendRadar service so `python -m trendradar` works.
TRENDRADAR_IMAGE=local/trendradar:6.10.0

# Admin bind address and port.
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8081

# Manual run timeout in seconds.
TRENDRADAR_RUN_TIMEOUT=900

# Set to 1 to start/recreate the admin container after installing files.
START_ADMIN=1

